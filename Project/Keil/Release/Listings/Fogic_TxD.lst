 401          /* ============================================================================
 402             主函数
 403             流程：
 404               上电 -> 休眠
 405               唤醒（按键）->  g_mode切换 -> 立即发RF -> 显示5s -> 休眠
 406               显示中再次按键 -> 立即切换到下一模式 -> 重新发RF -> 重新计5s
 407             ============================================================================ */
 408          void main( void )
 409          {
 410   1          system_init();
 411   1          rf_spi_init();
 412   1      
 413   1          GPIO_Init();
 414   1          Fogic_RFM_Init();
 415   1          Fogic_RFM_BufInit();
 416   1          LED_ALL_OFF();
 417   1      
 418   1          Enter_Sleep();              /* 上电休眠，等待首次按键 */
 419   1      
 420   1          while( 1 )
 421   1          {
 422   2              g_rekey = 0;                        /* 清中断标志           */
 423   2              g_mode  = (g_mode + 1) % 11;       /* 切换到下一模式（0~10循环）*/
 424   2              Fogic_RF_Send( KFN_GO_STOP );       /* 立即发送RF           */
C51 COMPILER V9.52.0.0   FOGIC_TXD                                                         06/06/2026 21:26:43 PAGE 8   

 425   2              LED_ShowMode();                     /* 显示当前模式5秒      */
 426   2      
 427   2              if( g_rekey )
 428   2              {
 429   3                  /* 显示期间被按键中断：不休眠，直接切换下一模式 */
 430   3                  continue;
 431   3              }
 432   2      
 433   2              /* 5秒正常显示完毕，进入休眠 */
 434   2              Enter_Sleep();
 435   2          }
 436   1      }
