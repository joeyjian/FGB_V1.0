 225          /* ============================================================================
 226             模式10：全彩渐变（8色顺序平滑过渡一整圈，每段约63帧，8段≈500帧）
 227             ============================================================================ */
 228          static void mode_rainbow_fade(void)
 229          {
 230   1          u8 c, nc;
 231   1          u16 total;
 232   1          total = 0;
 233   1          c = 0;
 234   1          while( total < SHOW_FRAMES && !g_rekey )
 235   1          {
 236   2              nc = (c + 1) % 8;
 237   2              total += do_fade(
 238   2                  COLORS[c][0],  COLORS[c][1],  COLORS[c][2],
 239   2                  COLORS[nc][0], COLORS[nc][1], COLORS[nc][2],
C51 COMPILER V9.52.0.0   FOGIC_TXD                                                         05/24/2026 16:55:24 PAGE 5   

 240   2                  63
 241   2              );
 242   2              c = nc;
 243   2          }
 244   1      }
