 178   3                  v = (u8)(i / 5);    /* 0~9 */
 179   3                  pwm_frame(v, v, v);
 180   3              }
 181   2              /* 下降50帧 */
 182   2              for( i = 0; i < 50 && total < SHOW_FRAMES && !g_rekey; i++, total++ )
 183   2              {
 184   3                  v = (u8)((49 - i) / 5);
 185   3                  pwm_frame(v, v, v);
 186   3              }
 187   2          }
 188   1      }
 189          
 190          /* ============================================================================
 191             模式9：彩色呼吸（每种颜色各呼吸一次，每次100帧=1s）
 192             5秒 = 5种颜色各呼吸一次
 193             ============================================================================ */
 194          static void mode_breath_color(void)
 195          {
 196   1          u8 c, i, v;
 197   1          u16 total;
 198   1          total = 0;
 199   1          c = 0;
 200   1          while( total < SHOW_FRAMES && !g_rekey )
 201   1          {
 202   2              /* 上升50帧 */
