 152          /* ============================================================================
 153             模式0~7：单色常亮（显示5秒）
 154             ci = COLORS表索引（0~7对应红/橙/黄/绿/青/蓝/紫/品红）
 155             ============================================================================ */
 156          static void mode_solid( u8 ci )
 157          {
 158   1          u16 total;
 159   1          for( total = 0; total < SHOW_FRAMES && !g_rekey; total++ )
 160   1          {
 161   2              pwm_frame( COLORS[ci][0], COLORS[ci][1], COLORS[ci][2] );
 162   2          }
 163   1      }
