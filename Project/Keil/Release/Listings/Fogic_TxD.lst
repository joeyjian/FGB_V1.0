 136          /* ============================================================================
 137             8种颜色定义（R,G,B，亮度0~10）
 138             ============================================================================ */
 139          /* 七彩8色表 */
 140          static const u8 code COLORS[8][3] = {
 141              {10, 0, 0},   /* 0 红   */
 142              {10, 4, 0},   /* 1 橙   */
 143              { 8, 8, 0},   /* 2 黄   */
 144              { 0,10, 0},   /* 3 绿   */
 145              { 0, 8, 6},   /* 4 青   */
 146              { 0, 0,10},   /* 5 蓝   */
 147              { 5, 0,10},   /* 6 紫   */
 148              {10, 0, 5},   /* 7 品红 */
 149          };
 150          
 151          /* ============================================================================
 152             模式0~7：单色常亮（显示5秒）
 153             ci = COLORS表索引（0~7对应红/橙/黄/绿/青/蓝/紫/品红）
 154             ============================================================================ */
 155          static void mode_solid( u8 ci )
 156          {
 157   1          u16 total;
 158   1          for( total = 0; total < SHOW_FRAMES && !g_rekey; total++ )
 159   1          {
 160   2              pwm_frame( COLORS[ci][0], COLORS[ci][1], COLORS[ci][2] );
 161   2          }
 162   1      }
 163          
 164          /* ============================================================================
 165             模式8：白色呼吸（亮度0→满→0，每圈100帧=1s，5秒约5圈）
 166             ============================================================================ */
 167          static void mode_breath_white(void)
 168          {
 169   1          u16 total;
 170   1          u8 v, i;
 171   1          total = 0;
 172   1          while( total < SHOW_FRAMES && !g_rekey )
 173   1          {
 174   2              /* 上升50帧 */
 175   2              for( i = 0; i < 50 && total < SHOW_FRAMES && !g_rekey; i++, total++ )
 176   2              {
 177   3                  v = (u8)(i / 5);    /* 0~9 */
C51 COMPILER V9.52.0.0   FOGIC_TXD                                                         05/24/2026 16:55:24 PAGE 4   

 178   3                  pwm_frame(v, v, v);
 179   3              }
 180   2              /* 下降50帧 */
 181   2              for( i = 0; i < 50 && total < SHOW_FRAMES && !g_rekey; i++, total++ )
 182   2              {
 183   3                  v = (u8)((49 - i) / 5);
 184   3                  pwm_frame(v, v, v);
 185   3              }
 186   2          }
 187   1      }
 188          
 189          /* ============================================================================
 190             模式9：彩色呼吸（每种颜色各呼吸一次，每次100帧=1s）
 191             5秒 = 5种颜色各呼吸一次
 192             ============================================================================ */
 193          static void mode_breath_color(void)
 194          {
 195   1          u8 c, i, v;
 196   1          u16 total;
 197   1          total = 0;
 198   1          c = 0;
 199   1          while( total < SHOW_FRAMES && !g_rekey )
 200   1          {
 201   2              /* 上升50帧 */
 202   2              for( i = 0; i < 50 && total < SHOW_FRAMES && !g_rekey; i++, total++ )
 203   2              {
 204   3                  v = (u8)(i / 5);
 205   3                  pwm_frame(
 206   3                      (u8)((u16)COLORS[c][0] * v / 10),
 207   3                      (u8)((u16)COLORS[c][1] * v / 10),
 208   3                      (u8)((u16)COLORS[c][2] * v / 10)
 209   3                  );
 210   3              }
 211   2              /* 下降50帧 */
 212   2              for( i = 0; i < 50 && total < SHOW_FRAMES && !g_rekey; i++, total++ )
 213   2              {
 214   3                  v = (u8)((49 - i) / 5);
 215   3                  pwm_frame(
 216   3                      (u8)((u16)COLORS[c][0] * v / 10),
 217   3                      (u8)((u16)COLORS[c][1] * v / 10),
 218   3                      (u8)((u16)COLORS[c][2] * v / 10)
 219   3                  );
 220   3              }
 221   2              c = (c + 1) % 8;
 222   2          }
 223   1      }
