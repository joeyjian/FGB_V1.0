 216   3                  pwm_frame(
 217   3                      (u8)((u16)COLORS[c][0] * v / 10),
 218   3                      (u8)((u16)COLORS[c][1] * v / 10),
 219   3                      (u8)((u16)COLORS[c][2] * v / 10)
 220   3                  );
 221   3              }
 222   2              c = (c + 1) % 8;
 223   2          }
 224   1      }
