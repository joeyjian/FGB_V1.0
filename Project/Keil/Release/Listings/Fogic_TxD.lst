 287          static void Fogic_RFM_BufInit( void )
 288          {
 289   1          u8 i;
 290   1          RFM_Buf[0] = 'F';
 291   1          RFM_Buf[1] = 0;
 292   1          for( i = 2; i < 14; i++ ) RFM_Buf[i] = 0x00;
 293   1          RFM_Buf[14] = KEY_NO_FUNC;
 294   1          RFM_Buf[15] = 0x00;
 295   1      }
 296          
 297          static void Fogic_RF_Send( u8 key_func )
 298          {
 299   1          u8 i;
 300   1          RFM_Buf[1]++;
 301   1          RFM_Buf[14] = key_func | 0x10;
C51 COMPILER V9.52.0.0   FOGIC_TXD                                                         05/24/2026 16:55:24 PAGE 6   

 302   1          RFM_Buf[15] = Fogic_GetCRC( RFM_Buf, FOGIC_PAYLOAD_LEN_END );
 303   1      
 304   1          for( i = 0; i < FOGIC_RESEND_CNTS_MAX; i++ )
 305   1          {
 306   2              rf_flush_tx();
 307   2              rf_clear_all_irq();
 308   2              rf_send_pack( CMD_W_TX_PAYLOAD, RFM_Buf, FOGIC_PAYLOAD_LEN_MAX );
 309   2              rf_ce_high();
 310   2              delay_ms( 2 );
 311   2              rf_ce_low();
 312   2              rf_flush_tx();
 313   2              rf_clear_all_irq();
 314   2              delay_ms( 2 );
 315   2          }
 316   1      }
