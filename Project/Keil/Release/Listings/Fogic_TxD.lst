 394          /* ============================================================================
 395             主函数
 396             流程：
 397               上电 -> 休眠
 398               唤醒（按键）->  g_mode切换 -> 立即发RF -> 显示5s -> 休眠
 399               显示中再次按键 -> 立即切换到下一模式 -> 重新发RF -> 重新计5s
 400             ============================================================================ */
 401          void main( void )
 402          {
 403   1          system_init();
 404   1          rf_spi_init();
 405   1      
 406   1          GPIO_Init();
 407   1          Fogic_RFM_Init();
 408   1          Fogic_RFM_BufInit();
 409   1          LED_ALL_OFF();
 410   1      
 411   1          Enter_Sleep();              /* 上电休眠，等待首次按键 */
 412   1      
 413   1          while( 1 )
 414   1          {
 415   2              g_rekey = 0;                        /* 清中断标志           */
 416   2              g_mode  = (g_mode + 1) % 11;       /* 切换到下一模式（0~10循环）*/
 417   2              Fogic_RF_Send( KFN_GO_STOP );       /* 立即发送RF           */
 418   2              LED_ShowMode();                     /* 显示当前模式5秒      */
 419   2      
 420   2              if( g_rekey )
 421   2              {
 422   3                  /* 显示期间被按键中断：不休眠，直接切换下一模式 */
 423   3                  continue;
 424   3              }
C51 COMPILER V9.52.0.0   FOGIC_TXD                                                         05/24/2026 16:55:24 PAGE 8   

 425   2      
 426   2              /* 5秒正常显示完毕，进入休眠 */
 427   2              Enter_Sleep();
 428   2          }
 429   1      }
