  74          /* ============================================================================
  75             渲染一帧（软件PWM，10ms）
  76             同时检测按键：若P15持续按下超过消抖时间则置g_rekey
  77             ============================================================================ */
  78          static void pwm_frame( u8 r, u8 g, u8 b )
  79          {
  80   1          u8 t;
  81   1          for( t = 0; t < PWM_MAX; t++ )
  82   1          {
  83   2              SET_R( t < r );
  84   2              SET_G( t < g );
  85   2              SET_B( t < b );
  86   2              delay_ms( PWM_STEP_MS );
  87   2      
  88   2              if( P15 == 1 )
  89   2              {
  90   3                  /* 消抖：持续检测80ms，全部为高电平才确认 */
  91   3                  u8 d;
  92   3                  for( d = 0; d < 80; d++ )
  93   3                  {
  94   4                      delay_ms( 1 );
  95   4                      if( P15 == 0 ) return;  /* 中途松开，判为抖动，忽略 */
  96   4                  }
  97   3                  /* 确认为有效按键：等待松开后再响应 */
  98   3                  while( P15 == 1 ) { delay_ms( 5 ); }
  99   3                  delay_ms( 50 );             /* 松手后再等50ms防弹跳     */
 100   3                  LED_ALL_OFF();
 101   3                  g_rekey = 1;
 102   3                  return;
 103   3              }
 104   2          }
 105   1      }
 106          
 107          /* ============================================================================
 108             线性插值辅助（避免重复代码）
 109             从 a 渐变到 b，当前步 i，总步数 steps
 110             ============================================================================ */
 111          static u8 lerp( u8 a, u8 b, u8 i, u8 steps )
 112          {
 113   1          if( b >= a ) return (u8)( a + (u16)(b - a) * i / steps );
 114   1          else         return (u8)( a - (u16)(a - b) * i / steps );
 115   1      }
C51 COMPILER V9.52.0.0   FOGIC_TXD                                                         05/24/2026 16:55:24 PAGE 3   

 116          
 117          /* ============================================================================
 118             渐变一段：从(r0,g0,b0)到(r1,g1,b1)，共steps帧
 119             返回实际执行的帧数（被按键中断则提前返回）
 120             ============================================================================ */
 121          static u8 do_fade( u8 r0, u8 g0, u8 b0,
 122                             u8 r1, u8 g1, u8 b1,
 123                             u8 steps )
 124          {
 125   1          u8 i;
 126   1          for( i = 0; i < steps; i++ )
 127   1          {
 128   2              if( g_rekey ) return i;
 129   2              pwm_frame( lerp(r0,r1,i,steps),
 130   2                         lerp(g0,g1,i,steps),
 131   2                         lerp(b0,b1,i,steps) );
 132   2          }
 133   1          return steps;
 134   1      }
