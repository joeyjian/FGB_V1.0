  75          /* ============================================================================
  76             渲染一帧（软件PWM，10ms）
  77             同时检测按键：若P15持续按下超过消抖时间则置g_rekey
  78             ============================================================================ */
  79          static void pwm_frame( u8 r, u8 g, u8 b )
  80          {
  81   1          u8 t;
  82   1          for( t = 0; t < PWM_MAX; t++ )
  83   1          {
  84   2              SET_R( t < r );
  85   2              SET_G( t < g );
  86   2              SET_B( t < b );
  87   2              delay_ms( PWM_STEP_MS );
  88   2      
  89   2              if( P15 == 1 )
  90   2              {
  91   3                  /* 消抖：持续检测80ms，全部为高电平才确认 */
  92   3                  u8 d;
  93   3                  for( d = 0; d < 80; d++ )
  94   3                  {
  95   4                      delay_ms( 1 );
  96   4                      if( P15 == 0 ) return;  /* 中途松开，判为抖动，忽略 */
  97   4                  }
  98   3                  /* 确认为有效按键：等待松开后再响应 */
  99   3                  while( P15 == 1 ) { delay_ms( 5 ); }
 100   3                  delay_ms( 50 );             /* 松手后再等50ms防弹跳     */
 101   3                  LED_ALL_OFF();
 102   3                  g_rekey = 1;
 103   3                  return;
 104   3              }
 105   2          }
 106   1      }
