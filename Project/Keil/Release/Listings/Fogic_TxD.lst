 108          /* ============================================================================
 109             线性插值辅助（避免重复代码）
 110             从 a 渐变到 b，当前步 i，总步数 steps
 111             ============================================================================ */
 112          static u8 lerp( u8 a, u8 b, u8 i, u8 steps )
 113          {
 114   1          if( b >= a ) return (u8)( a + (u16)(b - a) * i / steps );
 115   1          else         return (u8)( a - (u16)(a - b) * i / steps );
C51 COMPILER V9.52.0.0   FOGIC_TXD                                                         06/06/2026 21:26:43 PAGE 3   

 116   1      }
 117          
 118          /* ============================================================================
 119             渐变一段：从(r0,g0,b0)到(r1,g1,b1)，共steps帧
 120             返回实际执行的帧数（被按键中断则提前返回）
 121             ============================================================================ */
 122          static u8 do_fade( u8 r0, u8 g0, u8 b0,
 123                             u8 r1, u8 g1, u8 b1,
 124                             u8 steps )
 125          {
 126   1          u8 i;
 127   1          for( i = 0; i < steps; i++ )
 128   1          {
 129   2              if( g_rekey ) return i;
 130   2              pwm_frame( lerp(r0,r1,i,steps),
 131   2                         lerp(g0,g1,i,steps),
 132   2                         lerp(b0,b1,i,steps) );
 133   2          }
 134   1          return steps;
 135   1      }
