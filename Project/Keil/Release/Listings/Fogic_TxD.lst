   1          /**
   2            ******************************************************************************
   3            * @file    Fogic_TxD.c
   4            * @brief   按键切换8种LED模式，每次按键：立即发RF -> 显示5s -> 休眠
   5            *
   6            * 按键每按一次，模式依次循环（0->1->...->10->0）：
   7            *   模式0:  常亮-红
   8            *   模式1:  常亮-橙
   9            *   模式2:  常亮-黄
  10            *   模式3:  常亮-绿
  11            *   模式4:  常亮-青
  12            *   模式5:  常亮-蓝
  13            *   模式6:  常亮-紫
  14            *   模式7:  常亮-品红
  15            *   模式8:  白色呼吸     亮度0->满->0，循环
  16            *   模式9:  彩色呼吸     每种颜色各完整呼吸一次
  17            *   模式10: 全彩渐变     红->橙->黄->绿->青->蓝->紫->红 平滑过渡
  18            *
  19            * 显示期间再次按键：立即重新发RF，切换到下一模式并重新计5s
  20            *
  21            * 硬件：
  22            *   KEY3  P15 --- VCC   按下=高电平，内部下拉
  23            *   LED共阴，高电平点亮：LED_R=P05 / LED_G=P01 / LED_B=P06
  24            *
  25            * 软件PWM：每帧10ms（10片×1ms），分辨率0~10
  26            ******************************************************************************
  27            */
  28          
  29          #ifndef __FOGIC_TXD_C__
  30          #define __FOGIC_TXD_C__
  31          
  32          #include "include.h"
  33          #if( FOGIC_PROG_TYP == FOGIC_PROG_TXD )
  34          
  35          /* ============================================================================
  36             PWM参数
  37             ============================================================================ */
  38          #define PWM_MAX     10          /* PWM最大亮度，每帧10ms */
  39          #define PWM_STEP_MS 1           /* 每时间片1ms            */
  40          
  41          /* 5秒 = 5000ms / 10ms每帧 = 500帧 */
  42          #define SHOW_FRAMES 500
  43          
  44          /* ============================================================================
  45             LED控制宏（共阳低有效，与原始完全一致）
  46             ============================================================================ */
  47          #define SET_R(on)     do{ P05 = (on) ? 1 : 0; }while(0)   /* R -> P05, 共阴高有效 */
  48          #define SET_G(on)     do{ P01 = (on) ? 1 : 0; }while(0)   /* G -> P01, 共阴高有效 */
  49          #define SET_B(on)     do{ P06 = (on) ? 1 : 0; }while(0)   /* B -> P06, 共阴高有效 */
  50          #define LED_ALL_OFF() do{ P05=0; P01=0; P06=0; }while(0)
  51          
  52          /* ============================================================================
  53             全局变量（与原始完全一致）
C51 COMPILER V9.52.0.0   FOGIC_TXD                                                         05/24/2026 16:55:24 PAGE 2   

  54             ============================================================================ */
  55          u8  RFM_Buf[ FOGIC_PAYLOAD_LEN_MAX ];
  56          
