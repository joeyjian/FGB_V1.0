 247          /* ============================================================================
 248             显示当前模式（5秒）
 249             ============================================================================ */
 250          static void LED_ShowMode(void)
 251          {
 252   1          switch( g_mode )
 253   1          {
 254   2              case  0: mode_solid(0);        break;  /* 常亮-红   */
 255   2              case  1: mode_solid(1);        break;  /* 常亮-橙   */
 256   2              case  2: mode_solid(2);        break;  /* 常亮-黄   */
 257   2              case  3: mode_solid(3);        break;  /* 常亮-绿   */
 258   2              case  4: mode_solid(4);        break;  /* 常亮-青   */
 259   2              case  5: mode_solid(5);        break;  /* 常亮-蓝   */
 260   2              case  6: mode_solid(6);        break;  /* 常亮-紫   */
 261   2              case  7: mode_solid(7);        break;  /* 常亮-品红 */
 262   2              case  8: mode_breath_white();  break;  /* 白色呼吸  */
 263   2              case  9: mode_breath_color();  break;  /* 彩色呼吸  */
 264   2              case 10: mode_rainbow_fade();  break;  /* 全彩渐变  */
 265   2              default: break;
 266   2          }
 267   1          LED_ALL_OFF();
 268   1      }
