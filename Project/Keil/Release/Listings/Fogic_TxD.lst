  58          u8  P1_MD0_Reg, P1_MD1_Reg;
  59          u8  P0_AF0_Reg, P0_AF1_Reg;
  60          u8  P1_AF0_Reg, P1_AF1_Reg;
  61          u8  P0_PU_Reg,  P1_PU_Reg;
  62          
