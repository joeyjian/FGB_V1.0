 206          /**
 207            * @brief  RF send data pack function
 208            * @param  cmd   : command to send packets
 209            * @param  p_buf : the pointer to write data  
 210            * @param  len   : data length, from 1 to 32 bytes
 211            * @retval None
 212            */
 213          void rf_send_pack(u8 cmd, u8 *p_buf, u8 len)
 214          {
 215   1          u8 sta;
 216   1          
 217   1          sta = rf_spi_read_byte(REG_BANK0_STATUS);
 218   1          if(!(sta & RF_STATUS_TX_FULL)) 
