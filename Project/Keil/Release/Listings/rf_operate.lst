 125            */
 126          void rf_bank_switch(TYPE_ENUM_BANK bank)
 127          {
 128   1          u8 sta;
 129   1          
 130   1          sta = rf_spi_read_byte(REG_BANK0_STATUS);
 131   1          if(bank != RF_BANK0) 
 132   1        {
 133   2              if(!(sta & (RF_BANK1 << 7))) 
 134   2          {
 135   3                  rf_spi_write_cmd_data(CMD_ACTIVATE, CMD_ACTIVATE_DATA);
 136   3              }
 137   2          } 
 138   1        else 
 139   1        {
 140   2              if(sta & (RF_BANK1 << 7)) 
 141   2          {
 142   3                  rf_spi_write_cmd_data(CMD_ACTIVATE, CMD_ACTIVATE_DATA);
 143   3              }
 144   2          }
 145   1      }
