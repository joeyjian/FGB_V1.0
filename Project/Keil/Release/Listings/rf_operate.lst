 262          /**
 263            * @brief  RF set rate function
 264            * @param  rate : the rate to set
 265            * @retval None
 266            */
 267          void rf_set_rate(TYPE_ENUM_RATE rate)
 268          {
 269   1          u8 val;
 270   1          val = rf_spi_read_byte(REG_BANK0_RF_SETUP);
 271   1          switch(rate) {
 272   2              case RF_RATE_1M:
 273   2                  val &= 0xf7;
 274   2                  rf_spi_write_byte(REG_BANK0_RF_SETUP, val);
 275   2                  break;
 276   2              case RF_RATE_2M:
 277   2                  val |= 0x08;
 278   2                  rf_spi_write_byte(REG_BANK0_RF_SETUP, val);
 279   2                  break;
 280   2              default:
 281   2                  break;
 282   2          }
 283   1      }
