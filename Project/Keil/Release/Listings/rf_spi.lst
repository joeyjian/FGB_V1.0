  68          /**
  69            * @brief  RF spi write data function
  70            * @param  wdata : the data to be written
  71            * @retval None
  72            */
  73          void rf_spi_write_data(u8 wdata)
  74          {
  75   1          while(!(SPI0_STA & 0x01));
  76   1          // config tx mode
  77   1          SPI0_CON  &= ~(1 << 5);
  78   1          SPI0_DATA = wdata;
  79   1          while(!(SPI0_STA & 0x01));
  80   1      }
  81          
  82          /**
  83            * @brief  RF spi read data function
  84            * @param  None
  85            * @retval Read one byte of data
  86            */
  87          u8 rf_spi_read_data(void)
  88          {
  89   1          while(!(SPI0_STA & 0x01));
  90   1          // config rx mode
  91   1          SPI0_CON |= (1 << 5);
  92   1          // trigger receive data
  93   1          SPI0_DATA = 0x01; //NOP_N;
  94   1          while(!(SPI0_STA & (1 << 0)));
  95   1          return SPI0_DATA;
  96   1      }
  97          
  98          /**
  99            * @brief  RF spi write one byte function 
 100            * @param  addr  : address
 101            * @param  wdata : the data to be written
 102            * @retval None
 103            */
 104          void rf_spi_write_byte(u8 addr, u8 wdata)
 105          { 
 106   1          CSN_LOW;
 107   1          rf_spi_write_data(CMD_W_REGISTER | addr);
 108   1          rf_spi_write_data(wdata);
 109   1          CSN_HIGH;
 110   1      }
