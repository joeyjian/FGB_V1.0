 129            * @param  addr   : address
 130            * @param  p_data : the pointer to write data  
 131            * @param  len    : data length
 132            * @retval None
 133            */ 
 134          void rf_spi_write_buf(u8 addr, u8 *p_data, u8 len)
 135          {
 136   1          u8 i;
 137   1          CSN_LOW;
 138   1          rf_spi_write_data(CMD_W_REGISTER | addr);
 139   1          for(i = 0; i < len; i++) {
 140   2              rf_spi_write_data(p_data[i]);
 141   2          }
 142   1          CSN_HIGH;
 143   1      }
