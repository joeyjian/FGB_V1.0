 116            */
 117          u8 rf_spi_read_byte(u8 addr)
 118          {
 119   1          u8 rdata;
 120   1          CSN_LOW;
 121   1          rf_spi_write_data(CMD_R_REGISTER | addr);
 122   1          rdata = rf_spi_read_data();
 123   1          CSN_HIGH;
