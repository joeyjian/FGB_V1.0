  32          /**
  33            * @brief  RF spi initialization function
  34            * @param  None
  35            * @retval None
  36            */
  37          void rf_spi_init(void)
  38          {
  39   1          // P03: spi data in and out
  40   1          // P02: spi clk
  41   1          P0_AF0 &= ~0xf0;
  42   1          P0_AF0 |= 0x50;
  43   1          // P03: io output
  44   1          // P02: io output
  45   1          P0_MD0 &= ~0xf0;
  46   1          // pull down spi clk
  47   1          P0_PD |= (1 << 2);
  48   1          P0_MD0 |=  0xa0;
  49   1          // P00: io output, be used as software controlled cs_n
  50   1          P0_MD0 &= ~0x3;
  51   1          P0_MD0 |=  0x1;
  52   1          // pull up cs_n
  53   1          P0_PU |= (1 << 0);
C51 COMPILER V9.52.0.0   RF_SPI                                                            06/06/2026 21:26:43 PAGE 2   

  54   1          // reset spi
  55   1          SYS_CON0 &= (~0x4);
  56   1          // enable clock of spi controller
  57   1          CLK_CON3 |= 0x4;
  58   1          // dereset spi
  59   1          SYS_CON0 |= 0x4;
  60   1          // baud rate
  61   1          SPI0_BAUD = SPI_BAUD;  
  62   1          // enable spi
  63   1          SPI0_CON |= 0x05;
  64   1          
  65   1          CSN_HIGH;
  66   1      }
